BEECRAWL_USER_AGENT=BeeCrawl/0.1 (+https://github.com/jacoobwang/beecrawl)
BEECRAWL_REQUEST_TIMEOUT_SECONDS=20
BEE_ENGINE_URL=http://127.0.0.1:8020
BEE_ENGINE_MAX_PAGES=4
BEECRAWL_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:55432/beecrawl
BEECRAWL_WEBHOOK_HMAC_SECRET=replace-with-a-long-random-secret
# Optional outbound HTTP(S) or SOCKS5 proxy, including credentials if required.
# BEECRAWL_PROXY_URL=http://username:password@proxy.example.com:8080
# BEECRAWL_STEALTH_PROXY_URL=http://username:password@residential.example.com:8080
# BEECRAWL_ENHANCED_PROXY_URL=http://username:password@premium.example.com:8080
# Optional HTTP service that performs browser-profile TLS impersonation.
# BEECRAWL_TLS_CLIENT_URL=http://127.0.0.1:8020/fetch
# BEECRAWL_TLS_CLIENT_PROFILE=chrome_124
BEECRAWL_DATABASE_MAX_CONNECTIONS=10
BEECRAWL_WORKER_ID=
BEECRAWL_CRAWL_RETENTION_DAYS=7
BEECRAWL_CRAWL_CLEANUP_INTERVAL_SECONDS=3600
BEECRAWL_SCRAPE_CACHE_MAX_AGE_SECONDS=14400
BEECRAWL_SCRAPE_CACHE_RETENTION_DAYS=7
BEECRAWL_LLM_PROVIDER=openai-compatible
BEECRAWL_LLM_API_KEY=
BEECRAWL_LLM_BASE_URL=https://api.openai.com/v1
BEECRAWL_LLM_MODEL=gpt-4o-mini
