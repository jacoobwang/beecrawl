{
  "openapi": "3.1.0",
  "info": {
    "title": "BeeCrawl API",
    "version": "0.1.0",
    "description": "Self-hosted web scraping API with Firecrawl-compatible v2 routes. Request and response option schemas are intentionally extensible; see firecrawl-compatibility.mdx for supported semantics."
  },
  "servers": [{"url": "http://127.0.0.1:8000"}],
  "security": [{"ApiKey": []}],
  "components": {
    "securitySchemes": {"ApiKey": {"type": "apiKey", "in": "header", "name": "X-Web-Extract-Api-Key"}},
    "schemas": {"JsonObject": {"type": "object", "additionalProperties": true}}
  },
  "paths": {
    "/health": {"get": {"security": [], "responses": {"200": {"description": "Service health"}}}},
    "/metrics": {"get": {"security": [], "responses": {"200": {"description": "Prometheus metrics"}}}},
    "/openapi.json": {"get": {"security": [], "responses": {"200": {"description": "OpenAPI 3.1 document"}}}},
    "/scrape": {"post": {"responses": {"200": {"description": "Scraped document"}}}},
    "/crawl": {"post": {"responses": {"202": {"description": "Crawl job"}}}},
    "/crawl/{id}": {"get": {"responses": {"200": {"description": "Crawl status"}}}, "delete": {"responses": {"200": {"description": "Cancelled"}}}},
    "/batch/scrape": {"post": {"responses": {"202": {"description": "Batch job"}}}},
    "/batch/scrape/{id}": {"get": {"responses": {"200": {"description": "Batch status"}}}, "delete": {"responses": {"200": {"description": "Cancelled"}}}},
    "/map": {"post": {"responses": {"200": {"description": "Links"}}}},
    "/search": {"post": {"responses": {"200": {"description": "Search results"}}}},
    "/extract": {"post": {"responses": {"200": {"description": "Structured extraction"}}}},
    "/v2/scrape": {"post": {"responses": {"200": {"description": "Firecrawl document"}}}},
    "/v2/parse": {"post": {"responses": {"200": {"description": "Parsed multipart document"}}}},
    "/v2/parse/base64": {"post": {"responses": {"200": {"description": "Parsed Base64 document"}}}},
    "/v2/parse/reference": {"post": {"responses": {"200": {"description": "Parsed upload reference"}}}},
    "/v2/parse/upload-url": {"post": {"responses": {"200": {"description": "Upload reference"}}}},
    "/v2/parse/upload/{id}": {"put": {"responses": {"200": {"description": "Uploaded"}}}},
    "/v2/crawl": {"post": {"responses": {"202": {"description": "Crawl job"}}}},
    "/v2/crawl/active": {"get": {"responses": {"200": {"description": "Active crawls"}}}},
    "/v2/crawl/ongoing": {"get": {"responses": {"200": {"description": "Ongoing crawls"}}}},
    "/v2/crawl/{id}": {"get": {"responses": {"200": {"description": "Crawl status"}}}, "delete": {"responses": {"200": {"description": "Cancelled"}}}},
    "/v2/crawl/{id}/errors": {"get": {"responses": {"200": {"description": "Crawl errors"}}}},
    "/v2/batch/scrape": {"post": {"responses": {"202": {"description": "Batch job"}}}},
    "/v2/batch/scrape/{id}": {"get": {"responses": {"200": {"description": "Batch status"}}}, "delete": {"responses": {"200": {"description": "Cancelled"}}}},
    "/v2/batch/scrape/{id}/errors": {"get": {"responses": {"200": {"description": "Batch errors"}}}},
    "/v2/map": {"post": {"responses": {"200": {"description": "Firecrawl links"}}}},
    "/v2/extract": {"post": {"responses": {"200": {"description": "Firecrawl extraction"}}}},
    "/v2/search": {"post": {"responses": {"200": {"description": "Firecrawl search"}}}},
    "/v2/browser": {"get": {"responses": {"200": {"description": "Browser sessions"}}}, "post": {"responses": {"201": {"description": "Browser session"}}}},
    "/v2/browser/{id}": {"delete": {"responses": {"200": {"description": "Session closed"}}}},
    "/v2/browser/{id}/execute": {"post": {"responses": {"200": {"description": "Execution result"}}}},
    "/v2/browser/{id}/replay": {"get": {"responses": {"200": {"description": "Replay pages"}}}},
    "/v2/browser/{id}/replay/{pageId}": {"get": {"responses": {"200": {"description": "Replay snapshot"}}}},
    "/v2/interact": {"get": {"responses": {"200": {"description": "Browser sessions"}}}, "post": {"responses": {"201": {"description": "Browser session"}}}},
    "/v2/interact/{id}": {"delete": {"responses": {"200": {"description": "Session closed"}}}},
    "/v2/interact/{id}/execute": {"post": {"responses": {"200": {"description": "Execution result"}}}},
    "/v2/interact/{id}/replay": {"get": {"responses": {"200": {"description": "Replay pages"}}}},
    "/v2/interact/{id}/replay/{pageId}": {"get": {"responses": {"200": {"description": "Replay snapshot"}}}},
    "/v2/scrape/{id}/interact": {"post": {"responses": {"201": {"description": "Handoff session"}}}, "delete": {"responses": {"200": {"description": "Handoff closed"}}}},
    "/v2/agent": {"post": {"responses": {"202": {"description": "Agent job"}}}},
    "/v2/agent/{id}": {"get": {"responses": {"200": {"description": "Agent status"}}}, "delete": {"responses": {"200": {"description": "Agent cancelled"}}}},
    "/v2/monitor": {"get": {"responses": {"200": {"description": "Monitors"}}}, "post": {"responses": {"201": {"description": "Monitor"}}}},
    "/v2/monitor/{id}": {"get": {"responses": {"200": {"description": "Monitor"}}}, "patch": {"responses": {"200": {"description": "Updated monitor"}}}, "delete": {"responses": {"200": {"description": "Deleted monitor"}}}},
    "/v2/monitor/{id}/run": {"post": {"responses": {"202": {"description": "Monitor check"}}}},
    "/v2/monitor/{id}/checks": {"get": {"responses": {"200": {"description": "Monitor check history"}}}},
    "/v2/monitor/{id}/checks/{checkId}": {"get": {"responses": {"200": {"description": "Monitor check"}}}}
  }
}
