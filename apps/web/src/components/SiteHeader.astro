---
const docsUrl = "https://docs.beecrawl.dev/";

const products = [
  { slug: "search", title: "Search", copy: "Find relevant pages across the web." },
  { slug: "scrape", title: "Scrape", copy: "Turn any URL into clean, useful data." },
  { slug: "crawl", title: "Crawl", copy: "Traverse complete websites with control." },
];
---

<header class="site-header">
  <nav class="nav shell" aria-label="Primary navigation">
    <a class="brand" href="/"><span class="bee" aria-hidden="true"><span class="bee-wing bee-wing-left"></span><span class="bee-wing bee-wing-right"></span><span class="bee-body">🐝</span></span><span class="brand-copy">BeeCrawl<span class="brand-mark">.</span></span></a>
    <div class="nav-links">
      <div class="nav-products">
        <a class="nav-products-trigger" href="/products/search" aria-haspopup="true">
          Products <span class="nav-products-chevron" aria-hidden="true"></span>
        </a>
        <div class="products-menu" role="menu" aria-label="Products">
          <p class="products-menu-label">Products</p>
          {products.map((product) => (
            <a href={`/products/${product.slug}`} role="menuitem">
              <span class="products-menu-title">{product.title}</span>
              <span class="products-menu-copy">{product.copy}</span>
            </a>
          ))}
        </div>
      </div>
      <a href={docsUrl} target="_blank" rel="noopener noreferrer">API docs</a>
      <a href="/#use-cases">Use case</a>
      <a href="https://github.com/jacoobwang/beecrawl">GitHub</a>
    </div>
    <a class="nav-cta" href="https://dashboard.beecrawl.dev">Get started <span aria-hidden="true">-&gt;</span></a>
  </nav>
</header>
