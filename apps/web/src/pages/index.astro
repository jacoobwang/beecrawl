---
import { codeToHtml } from "shiki";
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";

const docsUrl = "https://docs.beecrawl.dev/";

const endpoints = [
  {
    route: "/scrape",
    title: "Turn any page into useful data.",
    copy: "Get clean markdown, HTML, links, and metadata in one request.",
  },
  {
    route: "/crawl",
    title: "Traverse whole sites with control.",
    copy: "Start a crawl, monitor its progress, and collect normalized results.",
  },
  {
    route: "/extract",
    title: "Ask for structure, receive structure.",
    copy: "Define the fields you need and get consistent extraction output.",
  },
];

const codeExamples = [
  {
    id: "python",
    label: "Python SDK",
    filename: "request.py",
    language: "python",
    code: `from beecrawl_sdk import BeeCrawlClient

client = BeeCrawlClient(
    api_key="YOUR_API_KEY",
    base_url="https://api.beecrawl.dev",
)
page = client.scrape(
    "https://example.com",
    formats=["markdown", "links"],
    use_browser="auto",
)

print(page["markdown"])`,
  },
  {
    id: "node",
    label: "Node SDK",
    filename: "request.js",
    language: "js",
    code: `import { BeeCrawlClient } from "beecrawl-sdk";

const client = new BeeCrawlClient({
  apiKey: "YOUR_API_KEY",
  baseUrl: "https://api.beecrawl.dev",
});

const page = await client.scrape(
  "https://example.com",
  {
    formats: ["markdown", "links"],
    use_browser: "auto",
  },
);

console.log(page.markdown);`,
  },
  {
    id: "rust",
    label: "Rust SDK",
    filename: "main.rs",
    language: "rust",
    code: `use beecrawl_sdk::BeeCrawlClient;
use serde_json::json;

#[tokio::main]
async fn main() -> beecrawl_sdk::Result<()> {
    let client = BeeCrawlClient::builder(
        "https://api.beecrawl.dev",
    )
    .api_key("YOUR_API_KEY")
    .build()?;

    let page = client.scrape(
        "https://example.com",
        json!({"formats": ["markdown", "links"]}),
    ).await?;

    println!("{}", page["markdown"]);
    Ok(())
}`,
  },
  {
    id: "curl",
    label: "cURL",
    filename: "terminal",
    language: "bash",
    code: `curl -X POST https://api.beecrawl.dev/scrape \\
  -H "X-Web-Extract-Api-Key: YOUR_API_KEY" \\
  -H "Content-Type: application/json" \\
  -d '{
    "url": "https://example.com",
    "formats": ["markdown", "links"],
    "use_browser": "auto"
  }'`,
  },
];

const resultExample = `# Example Domain

Example Domain is for use in illustrative
examples in documents and applications.

## Links

- https://www.iana.org/domains/example

---
source: https://example.com
status: 200`;

const highlightedCodeExamples = await Promise.all(
  codeExamples.map(async (example) => ({
    ...example,
    highlighted: await codeToHtml(example.code, {
      lang: example.language,
      theme: "github-dark-default",
    }),
  })),
);

const highlightedResult = await codeToHtml(resultExample, {
  lang: "markdown",
  theme: "github-dark-default",
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="BeeCrawl is an open-source API for reliable web extraction, crawling, mapping, and search."
    />
    <meta property="og:title" content="BeeCrawl | Web data, made useful." />
    <meta
      property="og:description"
      content="An open-source API for reliable web extraction, crawling, mapping, and search."
    />
    <meta property="og:image" content="/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="/og.png" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Beecrawl | The Web Data Infrastructure for AI</title>
    <style>
      .footer-legal { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding: 22px 0 26px; border-top: 1px solid var(--line); color: var(--muted); font: 700 10px/1.2 "SFMono-Regular", Consolas, monospace; letter-spacing: .07em; text-transform: uppercase; }
      .footer-legal-links { display: flex; gap: 36px; }
      .footer-legal a:hover { color: var(--lime); }
      @media (max-width: 600px) { .footer-legal { align-items: flex-start; flex-direction: column; gap: 16px; }.footer-legal-links { gap: 20px; } }
    </style>
  </head>
  <body>
    <div class="release-banner">
      <a href="https://github.com/jacoobwang/beecrawl">
        BeeCrawl is open source. Inspect the code on GitHub <span aria-hidden="true">-&gt;</span>
      </a>
    </div>

    <SiteHeader />

    <main>
      <section class="hero">
        <pre class="signal-field" aria-hidden="true">scrape  crawl  map  search  extract
00110011 01001010 10111000 00101101
markdown  html  links  metadata  json
11001010 01011100 00110001 10101001
response  ready  response  ready</pre>
        <div class="shell hero-grid">
          <div class="hero-copy">
            <p class="kicker">The open-source web data API</p>
            <h1>The Web Data Infrastructure for AI</h1>
            <p class="lede">
              The fastest Firecrawl alternative for AI agents.
            </p>
            <div class="actions">
              <a class="button button-dark" href={docsUrl} target="_blank" rel="noopener noreferrer">Read the API docs <span aria-hidden="true">-&gt;</span></a>
              <a class="text-link" href="#request">See a request <span aria-hidden="true">-&gt;</span></a>
            </div>
          </div>

          <div class="hero-visuals">
            <figure class="hero-art">
              <div class="hero-art-crop">
                <img src="/og.png" width="1200" height="630" alt="BeeCrawl API request and data nodes preview" />
              </div>
              <figcaption><span class="live-dot" aria-hidden="true"></span> Live API preview</figcaption>
            </figure>
            <div class="hero-stats" aria-label="BeeCrawl capabilities">
              <div><span>01</span><strong>Scrape</strong><p>Single-page extraction.</p></div>
              <div><span>02</span><strong>Crawl</strong><p>Site-level collection.</p></div>
              <div><span>03</span><strong>Extract</strong><p>Structured output.</p></div>
            </div>
          </div>
        </div>
      </section>

      <section class="code-showcase" aria-labelledby="code-heading">
        <div class="shell">
          <div class="code-showcase-heading">
            <p class="kicker">One request, useful output</p>
          </div>
          <div class="code-workbench" data-code-workbench>
            <div class="code-toolbar">
              <div class="code-tabs" role="tablist" aria-label="Code examples">
                {highlightedCodeExamples.map((example, index) => (
                  <button
                    class:list={["code-tab", { "is-active": index === 0 }]}
                    type="button"
                    role="tab"
                    aria-selected={index === 0 ? "true" : "false"}
                    data-code-tab={example.id}
                    data-filename={example.filename}
                  >
                    {example.label}
                  </button>
                ))}
              </div>
              <span>POST /scrape</span>
            </div>
            <div class="code-grid">
              <div class="code-pane" aria-label="BeeCrawl Python SDK example">
                <div class="pane-label"><span class="live-dot" aria-hidden="true"></span> <span data-code-filename>request.py</span></div>
                {highlightedCodeExamples.map((example, index) => (
                  <div
                    class="code-highlight"
                    data-code-example={example.id}
                    hidden={index !== 0}
                    set:html={example.highlighted}
                  />
                ))}
              </div>
              <div class="result-pane" aria-label="Fixed BeeCrawl scrape result">
                <div class="pane-label"><span class="result-dot" aria-hidden="true"></span> markdown</div>
                <div class="code-highlight result-highlight" set:html={highlightedResult} />
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="docs-section compatibility-section" style="border-bottom: 0"><div class="shell docs-two-column"><div><p class="kicker">Compatibility</p><h2>Already using<br /><em>Firecrawl?</em></h2></div><div class="docs-copy"><p>BeeCrawl also exposes Firecrawl v2-compatible routes for scrape, map, crawl, extract, and search. Set your SDK <code>api_key</code> and <code>base_url</code> to the BeeCrawl and keep your existing integration.</p><pre><code>POST /v2/scrape
POST /v2/map
POST /v2/crawl
POST /v2/extract
POST /v2/search</code></pre></div></div></section>

      <section id="use-cases" class="use-cases" aria-labelledby="use-cases-heading">
        <div class="shell">
          <div class="use-cases-heading">
            <p class="kicker">Use cases</p>
          </div>
          <article class="use-case-card">
            <div class="use-case-logo" aria-hidden="true">
              <img src="/logos/workus-icon.png" width="512" height="512" alt="" />
            </div>
            <div>
              <p class="use-case-label">Customer case</p>
              <h3>workus.ai</h3>
              <p>
                Workus.ai uses BeeCrawl web extraction to help agents read company pages,
                supplier profiles, and public web sources as structured research context.
              </p>
            </div>
            <a class="text-link" href="https://workus.ai">Visit site <span aria-hidden="true">-&gt;</span></a>
          </article>
        </div>
      </section>

      <section class="free-cta" aria-labelledby="free-cta-heading">
        <div class="shell free-cta-inner">
          <p class="kicker">No gatekeeping</p>
          <h2 id="free-cta-heading">It's now free</h2>
          <a class="button button-dark" href="https://dashboard.beecrawl.dev">Go to build <span aria-hidden="true">-&gt;</span></a>
        </div>
      </section>

      <script>
        const workbench = document.querySelector("[data-code-workbench]");

        if (workbench) {
          const tabs = Array.from(workbench.querySelectorAll<HTMLButtonElement>("[data-code-tab]"));
          const examples = Array.from(workbench.querySelectorAll<HTMLElement>("[data-code-example]"));
          const filename = workbench.querySelector<HTMLElement>("[data-code-filename]");

          for (const tab of tabs) {
            tab.addEventListener("click", () => {
              const selected = tab.dataset.codeTab;

              for (const candidate of tabs) {
                const isSelected = candidate === tab;
                candidate.classList.toggle("is-active", isSelected);
                candidate.setAttribute("aria-selected", String(isSelected));
              }

              for (const example of examples) {
                example.hidden = example.dataset.codeExample !== selected;
              }

              if (filename) filename.textContent = tab.dataset.filename ?? "request";
            });
          }
        }
      </script>

    </main>

    <footer class="site-footer">
      <div class="shell footer-inner">
        <a class="brand" href="/"><span class="bee" aria-hidden="true"><span class="bee-wing bee-wing-left"></span><span class="bee-wing bee-wing-right"></span><span class="bee-body">🐝</span></span><span class="brand-copy">BeeCrawl<span class="brand-mark">.</span></span></a>
        <p>Open-source web data infrastructure.</p>
        <a href={docsUrl} target="_blank" rel="noopener noreferrer">API docs</a>
        <a href="https://github.com/jacoobwang/beecrawl">GitHub</a>
      </div>
      <div class="footer-legal shell">
        <span>© 2026 BeeCrawl, Inc. All rights reserved.</span>
        <div class="footer-legal-links"><a href="/privacy-policy">Privacy policy</a><a href="/terms-of-service">Terms of service</a></div>
      </div>
    </footer>
  </body>
</html>
